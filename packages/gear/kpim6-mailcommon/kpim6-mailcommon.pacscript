  "kpim6-akonadi-dev"
  "kpim6-akonadi-mime-dev"
  "kpim6-kmailtransport-dev"
  "kpim6-kmime-dev"
  "kpim6-libkdepim-dev"
  "kpim6-mailimporter-dev"
  "kpim6-messagelib-dev"
  "kpim6-pimcommon-dev"
  "libqgpgmeqt6-dev"
  "qt6-5compat-dev"
