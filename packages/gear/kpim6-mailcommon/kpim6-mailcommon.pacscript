#!/usr/bin/env bash
# KPort pacscript — gear/kpim6-mailcommon
# Auto-generated by generate-pacscripts.sh — review before promoting to packages/
#
# KDE PIM email utility library, shared data The mail common library provides

# ── Standard Pacstall variables ───────────────────────────────────────────────

pkgname="kpim6-mailcommon"
pkgver="26.04.1"
pkgdesc="KDE PIM email utility library, shared data The mail common library provides"
# Fall back to invent.kde.org canonical URL when no homepage is set
url="http://pim.kde.org/"
license=("GPL-2.0-or-later")

source=(
