)

depends=(
  "kpim6-kdepim-runtime"
  "qt6-webengine"
)

makedepends=(
  "cmake"
  "kf6-kcodecs"
  "kf6-extra-cmake-modules"
  "kf6-karchive"
  "kf6-kauth"
  "kf6-kcmutils"
