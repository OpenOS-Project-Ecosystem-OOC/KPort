  "kf6-kglobalaccel"
  "kf6-ki18n"
  "kf6-kiconthemes"
  "kf6-kitemviews"
  "kf6-knewstuff"
  "kf6-knotifyconfig-dev"
  "kf6-kservice"
  "kf6-ktextaddons-dev"
  "kf6-ktexteditor-dev"
  "kf6-ktexttemplate-dev"
  "kf6-ktextwidgets"
  "kf6-kwallet"
  "kf6-kwidgetsaddons"
