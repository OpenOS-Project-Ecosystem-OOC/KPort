)

depends=(
  "plasma-activities"
)

makedepends=(
  "cmake"
  "doxygen"
  "kf6-extra-cmake-modules"
  "kf6-karchive"
  "kf6-kcmutils"
  "kf6-kcodecs"
  "kf6-kconfig"
  "kf6-kcontacts"
  "kf6-kdbusaddons"
  "kf6-ki18n"
  "kf6-knewstuff"
  "kf6-ktextaddons-dev"
  "kf6-ktexttemplate-dev"
  "kf6-ktextwidgets"
